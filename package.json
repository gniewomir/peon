{
  "name": "peon",
  "version": "1.0.0",
  "description": "Peon CLI",
  "type": "module",
  "bin": {
    "peon": "./dist/cli.js"
  },
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs && npx puppeteer browsers install chrome",
    "pre-commit": "node scripts/pre-commit.mjs",
    "commit-msg": "node scripts/commit-msg.mjs",
    "pre-push": "node scripts/pre-push.mjs",
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "peon": "node dist/cli.js",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "overkill": "npm run lint && npm run format && npm run test && npm run dist:clear && npm run build",
    "extract": "npm run peon -- extract",
    "transform": "npm run peon -- transform",
    "dist:clear": "node scripts/clear-dist.mjs",
    "stage:clear": "node scripts/clear-stage.mjs",
    "stage:repopulate": "node scripts/repopulate-staging.mjs",
    "cache:clear": "node scripts/clear-cache.mjs",
    "quarantine:clear": "node scripts/clear-quarantine.mjs",
    "all:clear": "node scripts/clear-all.mjs",
    "clean-run": "node scripts/clean-run.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@google/genai": "1.48.0",
    "@kreuzberg/html-to-markdown-node": "2.30.0",
    "cheerio": "1.2.0",
    "commander": "13.1.0",
    "dotenv": "17.3.1",
    "ollama": "0.6.3",
    "puppeteer": "24.40.0",
    "zod": "4.3.6"
  },
  "optionalDependencies": {
    "@kreuzberg/html-to-markdown-node-darwin-arm64": "2.30.0",
    "@kreuzberg/html-to-markdown-node-linux-x64-gnu": "3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.19.15",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  }
}
